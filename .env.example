# Bulk-IOC-Scanner Environment Variables
# Copy this file to backend/.env and fill in your API keys

# VirusTotal API key (v3) — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB API key (v2) — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# GreyNoise Community API key — https://viz.greynoise.io/account/api-key
GREYNOISE_API_KEY=

# ThreatFox / abuse.ch Auth-Key — https://auth.abuse.ch/
THREATFOX_AUTH_KEY=

# URLScan.io API key — https://urlscan.io/user/profile/
URLSCAN_API_KEY=

# Max single file upload size in MB (default: 1024 = 1 GB)
MAX_UPLOAD_MB=1024

# Max IOCs per single scan request (default: 200)
MAX_IOCS_PER_SCAN=200

# Reuse a stored result if the same IOC was scanned within this many hours
CACHE_TTL_HOURS=24

# Per-provider rate pacing (requests/min) — tuned to free-tier limits
VT_RATE_PER_MIN=4
ABUSEIPDB_RATE_PER_MIN=30

# Frontend origin for CORS — change if hosting elsewhere
FRONTEND_ORIGIN=http://localhost:5173

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./bulk_ioc_scanner.db
